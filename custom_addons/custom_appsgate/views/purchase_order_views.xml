<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_inherited" model="ir.ui.view">
        <field name="name">purchase_order_form_inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="replace">
                <field name="state" widget="statusbar"
                    statusbar_visible="draft,to_approve,approved_level1,approved_level2,purchase"
                    readonly="1" />
            </xpath>
            <xpath expr="//button[@name='button_confirm']"
            position="attributes">
                <attribute name="invisible">state not in ['sent', 'approved_level2']</attribute>
                <attribute name="groups">custom_appsgate.group_purchase_approver_level2</attribute>
        </xpath>
            
            <xpath expr="//button[@name='button_confirm']" position="after">
                <button type="object" name="action_approve_level1" class="btn btn-primary"
                    groups="custom_appsgate.group_purchase_approver_level1"
                    string="Approve Level 1" invisible="state not in ('to_approve')" />
                <button type="object" name="action_approve_level2" class="btn btn-primary"
                    groups="custom_appsgate.group_purchase_approver_level2"
                    string="Approve Level 2" invisible="state not in ('approved_level1')" />
                <button type="object" name="action_refuse" class="btn btn-primary"
                    groups="custom_appsgate.group_purchase_approver_level1"
                    string="Refuse" invisible="state not in ('to_approve')" />
                <button type="object" name="action_refuse" class="btn btn-primary"
                    groups="custom_appsgate.group_purchase_approver_level2"
                    string="Refuse" invisible="state not in ('approved_level1')" />
            </xpath>

            <field name="origin"
                position="after"
            >
                <field name="approval_level" readonly="1" />
            </field>
        </field>
    </record>
</odoo>