<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_sale_discount_rule_list" model="ir.ui.view">
        <field name="name">sale.discount.rule.list</field>
        <field name="model">sale.discount.rule</field>
        <field name="arch" type="xml">
            <list string="Discount Rules">
                <field name="name" />
                <field name="min_amount" />
                <field name="max_amount" />
                <field name="discount_percent" />
                <field name="valid_from" />
                <field name="valid_to" />
                <field name="active" />
            </list>
        </field>
    </record>

    <record id="view_sale_discount_rule_form" model="ir.ui.view">
        <field name="name">sale.discount.rule.form</field>
        <field name="model">sale.discount.rule</field>
        <field name="arch" type="xml">
            <form string="Tags">
                <sheet>
                    <div class="oe_title">
                        <label for="name" />
                        <h1>
                            <field name="name" placeholder="Rule Name" />
                        </h1>
                    </div>
                    <group>
                        <group string="Amount Details">
                            <field name="min_amount" />
                            <field name="max_amount" />
                            <field name="discount_percent" />
                        </group>
                        <group string="Validity Period">
                            <field name="valid_from" />
                            <field name="valid_to" />
                            <field name="active" />
                            <field name="company_id" groups="base.group_multi_company" />
                        </group>
                        <group>
                            <field name="customer_group" widget="many2many_tags" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sale_discount_rule" model="ir.actions.act_window">
        <field name="name">Discount Rules</field>
        <field name="res_model">sale.discount.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_sale_discount_rule" name="Discount Rules"
        action="action_sale_discount_rule" parent="sale.menu_sales_config"
        sequence="1" />

</odoo>