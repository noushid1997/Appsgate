<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form" model="ir.ui.view">
        <field name="name">dicount_sale_order_form_inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_confirm']" position="after">
                <button class="btn-secondary" string="Reapply Discount"
                    name="action_reapply_discount" type="object"
                    invisible="state not in ('draft')"
                />
            </xpath>
            <xpath expr="//field[@name='order_line']"
                position="after">
                <group>
                    <field name="applied_discount_rule_id"
                        readonly="1" options="{'no_create': True, 'no_open': True}" />
                </group>

            </xpath>

           <!-- ── Add Advance Payment field after payment_term_id ── -->
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="advance_payment"
                       widget="monetary"
                       options="{'currency_field': 'currency_id'}"
                       readonly="state not in ('draft', 'sent')"/>
                <field name="advance_payment_state"
                       widget="badge"
                       decoration-success="advance_payment_state == 'posted'"
                       decoration-danger="advance_payment_state == 'reversed'"
                       decoration-muted="advance_payment_state == 'none'"
                       invisible="advance_payment_state == 'none'"/>
            </xpath>

            <!-- ── Smart Button for Journal Entry ── -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_advance_entry"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-book"
                        invisible="not advance_move_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Advance</span>
                        <span class="o_stat_text">Entry</span>
                    </div>
                </button>
            </xpath>

            <!-- ── Reverse Advance button in header ── -->
            <xpath expr="//header" position="inside">
                <button name="action_reverse_advance_entry"
                        type="object"
                        string="Reverse Advance"
                        class="btn-secondary"
                        confirm="Are you sure you want to reverse the advance payment entry?"
                        invisible="not advance_move_id or advance_payment_state != 'posted'"/>
            </xpath>

            <!-- ── Advance Payment Details group ── -->
            <xpath expr="//group[@name='sale_shipping']" position="after">
                <group string="Advance Payment Details"
                       invisible="not advance_move_id">
                    <group>
                        <field name="advance_move_id" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>

    </record>

    <!-- Inherit Sale Order Tree View - optional column -->
    <record id="view_order_tree_advance_payment" model="ir.ui.view">
        <field name="name">sale.order.tree.advance.payment</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_quotation_tree_with_onboarding" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total']" position="after">
                <field name="advance_payment"
                    widget="monetary"
                    optional="hide" />
            </xpath>
        </field>
    </record>

</odoo>